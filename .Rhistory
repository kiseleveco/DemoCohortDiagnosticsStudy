connectionDetails <- DatabaseConnector::createConnectionDetails(dbms = DBMS,
user = USER,
password = PASSWORD,
server = SERVER,
port = DB_PORT,
pathToDriver = pathToDriver)
# The name of the database schema where the CDM data can be found:
